generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  name                   String?
  avatarUrl              String?
  password               String
  role                   String                  @default("CUSTOMER")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  targetConversations    Conversation[]          @relation("TargetConversations")
  userConversations      Conversation[]          @relation("UserConversations")
  mallAds                MallAd[]                @relation("AdminAds")
  sentMessages           Message[]               @relation("SentMessages")
  notifications          Notification[]
  notificationPreference NotificationPreference?
  publicViewCarousels    PublicViewCarousel[]
  publicViewConfigs      PublicViewConfig[]
  reviews                Review[]
  tenant                 Tenant?
  isBlacklisted         Boolean                 @default(false)
  eventInquiries         EventInquiry[]
}

model Tenant {
  id          String        @id @default(uuid())
  shopName    String
  unitId      String
  isOpen      Boolean       @default(true)
  description String?
  logoUrl     String?
  galleryUrls String[]      @default([])
  userId      String        @unique
  status      String        @default("ACTIVE")
  products    Json          @default("[]")
  postSales   Json          @default("[]")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  promos      TenantPromo[]
  invoices    Invoice[]
  reviews     Review[]
}

model Invoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique
  month           String
  amount          Float
  status          String   @default("PENDING")
  dueDate         DateTime
  description     String?
  depositSlipUrl  String?
  storageKey      String?
  referenceNo     String?
  tenantId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AreaSlot {
  id            String         @id @default(uuid())
  unit_id       String         @unique
  status        String         @default("AVAILABLE")
  sqm_size      Float
  base_rent     Float
  space_images  String[]       @default([])
  tenant_id     String?
  floor         String         @default("ground")
  category      String         @default("retail")
  x             Float          @default(0)
  y             Float          @default(0)
  width         Float          @default(120)
  height        Float          @default(80)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
}

model MallAd {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  linkUrl     String?  @default("/public-view")
  priority    String   @default("MEDIUM")
  startDate   DateTime
  endDate     DateTime
  isGlobal    Boolean  @default(true)
  adminId     String
  storageKey  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       User     @relation("AdminAds", fields: [adminId], references: [id])
}

model TenantPromo {
  id          String   @id @default(uuid())
  title       String
  description String?
  promoImage  String?
  promoVideo  String?
  category    String
  status      String   @default("PENDING")
  mediaType   String   @default("IMAGE")
  startDate   DateTime
  endDate     DateTime
  tenantId    String
  storageKey  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Conversation {
  id          String    @id @default(uuid())
  type        String
  userId      String
  targetId    String
  spaceSlotId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  areaSlot    AreaSlot? @relation(fields: [spaceSlotId], references: [id])
  target      User      @relation("TargetConversations", fields: [targetId], references: [id], onDelete: Cascade)
  user        User      @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
}

model Message {
  id             String       @id @default(uuid())
  content        String
  conversationId String
  senderId       String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model SiteConfig {
  id              String   @id @default("singleton")
  heroTitle       String   @default("Experience the Future of Shopping.")
  heroSubtitle    String   @default("Discover world-class retail, dining, and workspace solutions at SR Mall.")
  heroBadge       String   @default("Professional Mall Management System")
  heroBgUrl       String?
  heroOverlayDark Int      @default(40)
  primaryBtnText  String   @default("Explore Now")
  isMaintenance   Boolean  @default(false)
  defaultAdTitle  String   @default("Luxe Summer Sale")
  defaultAdDesc   String   @default("Experience up to 70% off on all premium luxury brands.")
  defaultAdImage  String?
  defaultAdCta    String   @default("View Directory")
  updatedAt       DateTime @updatedAt
}

model NotificationPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  newBookingInquiry    Boolean  @default(true)
  feedbackSpamDetected Boolean  @default(true)
  expiringContracts    Boolean  @default(true)
  overdueRentPayments  Boolean  @default(true)
  adSubmissionReceived Boolean  @default(false)
  systemHealthReports  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  tenantId   String?  // Optional: Null means it's a general mall review
  rating     Int
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

model PublicViewConfig {
  id                 String   @id @default(uuid())
  logoUrl            String?
  contactEmail       String?
  contactPhone       String?
  contactAddress     String?
  heroTitle          String?
  heroSubtitle       String?
  heroBgUrl          String?
  heroBadge          String?
  heroOverlayDark    Int      @default(40)
  adminId            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  aboutDescription   String?
  aboutImageUrl      String?
  aboutTitle         String?
  companyName        String?
  contactDescription String?
  contactTitle       String?
  featuredVideoUrl   String?
  videoDescription   String?
  videoTitle         String?
  admin              User?    @relation(fields: [adminId], references: [id])
}

model PublicViewCarousel {
  id          String    @id @default(uuid())
  title       String
  description String
  imageUrl    String
  linkUrl     String?
  isActive    Boolean   @default(true)
  adminId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  endDate     DateTime?
  priority    Int       @default(0)
  startDate   DateTime?
  storageKey  String?
  admin       User?     @relation(fields: [adminId], references: [id])
}

model EventInquiry {
  id        String   @id @default(uuid())
  userId    String
  eventType String
  eventDate DateTime
  eventTime String
  eventName String?
  message   String?
  imageUrl  String?
  storageKey String?
  status    String   @default("PENDING")
  fbAccount String?
  contactNumber String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
